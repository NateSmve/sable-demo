# ─── Site ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://yourclient.com
NEXT_PUBLIC_SITE_NAME="Client Business Name"

# ─── Stripe ──────────────────────────────────────────────────────────────────
# Get these from the Stripe Dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe price IDs for the deposit payment
# Create products in Stripe Dashboard, then paste the price IDs here
STRIPE_DEPOSIT_PRICE_ID=price_...

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# Sign up at resend.com — add client's domain
RESEND_API_KEY=re_...
CONTACT_EMAIL=hello@yourclient.com

# ─── Analytics ───────────────────────────────────────────────────────────────
# Vercel Analytics is enabled automatically on Vercel — no key needed
# Add GA4 if client wants Google Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-...
